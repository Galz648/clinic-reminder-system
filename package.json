{
  "name": "clinic-reminder-system",
  "version": "0.1.0",
  "private": true,
  "description": "Veterinary clinic reminder system — V0 scaffolding",
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:worker": "bun run worker/main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run scripts/ensure-schema.ts",
    "db:migrate:prod": "DATABASE_TARGET=production bun run scripts/ensure-schema.ts",
    "db:push": "bun run scripts/ensure-schema.ts",
    "db:studio": "drizzle-kit studio",
    "db:studio:prod": "DATABASE_TARGET=production drizzle-kit studio",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:precommit": "tsc -p tsconfig.build.json --noEmit",
    "test": "bun test",
    "test:precommit": "bun test test/clinica-*.test.ts src/reminders/reminders.service.spec.ts src/owners/dto/israeli-phone.util.spec.ts src/app.controller.spec.ts",
    "test:watch": "bun test --watch",
    "test:e2e": "bun test test/",
    "test:e2e:temporal": "bun test ./e2e/reminders.temporal.e2e.ts",
    "temporal:up": "docker compose up -d",
    "temporal:down": "docker compose down",
    "temporal:prod:tunnel": "scripts/temporal-prod-tunnel.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.12",
    "@nestjs/core": "^11.0.12",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.12",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "@nestjs/swagger": "^11.0.5",
    "@temporalio/activity": "^1.11.7",
    "@temporalio/client": "^1.11.7",
    "@temporalio/worker": "^1.11.7",
    "@temporalio/workflow": "^1.11.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.41.0",
    "libphonenumber-js": "^1.13.7",
    "pg": "^8.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.6",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.0.12",
    "@types/bun": "^1.2.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.14.0",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^7.0.0",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0"
  }
}
