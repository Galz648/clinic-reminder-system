# NestJS API
PORT=3000
API_PUBLIC_URL=http://localhost:3000

# App database — Supabase Postgres (same env var locally and in production)
# Local: docker compose service `supabase-db` (host port 54322 → container 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Production: paste from Supabase → Project Settings → Database → URI
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Temporal (local Docker Compose maps host 7233 → temporal:7233)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=reminder-queue

# Temporal UI (docker compose maps host 8080)
TEMPORAL_UI_URL=http://localhost:8080
