# NestJS API
PORT=3000
API_PUBLIC_URL=http://localhost:3000

# --- Database ---
# Local dev: docker compose `supabase-db` (user/password `postgres` — docker-compose.yml)
# Note: host port 54332 (54322 is often Supabase CLI)
DATABASE_URL=postgresql://postgres:postgres@localhost:54332/postgres

# Production: Supabase transaction-mode pooler (IPv4) — dashboard → Connect → ORM
# DATABASE_URL_PRODUCTION=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres

# Temporal (local Docker Compose maps host 7233 → temporal:7233)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=reminder-queue

# Temporal UI (docker compose maps host 8080)
TEMPORAL_UI_URL=http://localhost:8080

# Clinica Online (optional — enables clinic-online module when all four are set)
# CLINICA_BASE_URL=https://toran.clinicaonline.co.il
# CLINICA_USERNAME=
# CLINICA_PASSWORD=
# CLINICA_BRANCH_ID=41016_41002_0
# CLINICA_REMINDER_CATEGORY_ID=13
# CLINICA_SESSION_REFRESH_MS=900000
# CLINICA_SESSION_MAX_AGE_MS=1200000
